APP_NAME="Imenti POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=imenti_pos
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

SANCTUM_TOKEN_EXPIRATION=

# M-Pesa (Safaricom Daraja). MPESA_MOCK=true simulates an instant successful
# payment locally since no real Daraja credentials are configured here.
MPESA_ENV=sandbox
MPESA_MOCK=true
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://example.ngrok.io/api/v1/mpesa/callback
